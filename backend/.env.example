# Database Settings
DATABASE_URL="postgresql://postgres:your_password@db:5432/academic_portal"

# Server Settings
PORT="5000"
FRONTEND_URL="http://localhost:5173"

# Redis Cache Settings
REDIS_HOST="redis"
REDIS_PORT="6379"
REDIS_PASSWORD="redis_pass"

# JWT & Authentication
JWT_SECRET="generate_a_secure_jwt_secret_here"
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="admin_password_here"

# Google & Microsoft Auth
GOOGLE_CLIENT_ID="your_google_client_id"
MICROSOFT_CLIENT_ID="your_microsoft_client_id"
MICROSOFT_TENANT_ID="your_microsoft_tenant_id"

# Email settings (Resend)
RESEND_API_KEY="your_resend_api_key"
EMAIL_USER="your_email@example.com"
EMAIL_PASS="your_email_password"

# Supabase Admin
SUPABASE_URL="your_supabase_url"
SUPABASE_SERVICE_ROLE_KEY="your_supabase_service_role_key"

# Axiom Logging (Optional)
AXIOM_TOKEN="your_axiom_token"
AXIOM_ORG_ID="your_axiom_org_id"
AXIOM_DATASET="your_axiom_dataset"

# Misc
APP_LATEST_VERSION="1.0.0"
APP_APK_URL="your_apk_url"
FIREBASE_SERVICE_ACCOUNT_BASE64="your_base64_firebase_key"
