# ============================================
# 📊 Environment Variables Template
# ============================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ============================================

# ── Database ──────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=academic_portal
DB_USER=postgres
DB_PASSWORD=         # ← Set your database password

# OR use a connection string (Neon, Supabase, etc.)
# DATABASE_URL=postgresql://user:password@host:5432/database?sslmode=require

# ── Authentication ────────────────────────────
JWT_SECRET=          # ← Generate: openssl rand -hex 32

# ── Email Service (Resend) ────────────────────
RESEND_API_KEY=      # ← Get from https://resend.com
EMAIL_FROM=noreply@yourdomain.com

# ── Firebase (Push Notifications) ─────────────
# Place serviceAccountKey.json in backend/config/
FIREBASE_PROJECT_ID=

# ── Google OAuth ──────────────────────────────
GOOGLE_CLIENT_ID=

# ── App Version (Mobile Auto-Update) ──────────
APP_LATEST_VERSION=1.0.0
APP_APK_URL=
APP_RELEASE_NOTES=Bug fixes and improvements
APP_FORCE_UPDATE=false

# ── Server ────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Docker Compose Ports ──────────────────────
BACKEND_PORT=5000
FRONTEND_PORT=80

# ── Frontend Specific Variables ───────────────
VITE_API_URL=http://localhost:5000/api
VITE_SUPABASE_URL=          # ← Your Supabase Project URL
VITE_SUPABASE_ANON_KEY=     # ← Your Supabase Anon Key (needed for frontend)
